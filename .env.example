## PostgreSQL
POSTGRES_DB=webhooks
POSTGRES_USER=dispatcher
POSTGRES_PASSWORD=changeme

## Dispatcher
DATABASE_URL=postgresql://dispatcher:changeme@postgres:5432/webhooks

## SECURITY: Replace with output of:
##   python -c "import secrets; print(secrets.token_hex(32))"
## Must be the same value in both dispatcher and mock-receiver.
## Must be ≥32 characters.
WEBHOOK_SECRET=super-secret-webhook-key-change-in-prod-use-secrets-token-hex

TARGET_URL=http://mock-receiver:5000/webhook

## SSRF protection: set "true" ONLY in test environments where target is internal.
## In production, leave as "false" to block webhooks to private IP ranges.
ALLOW_PRIVATE_TARGETS=true

## CORS: leave empty for a backend API. Set to "https://yourdomain.com" for web UIs.
CORS_ORIGINS=

## Request size limit (bytes)
MAX_PAYLOAD_BYTES=1048576

## Worker tuning
WORKER_CONCURRENCY=3
POLL_INTERVAL_SECONDS=2
MAX_ATTEMPTS=10
REQUEST_TIMEOUT_SECONDS=10

## Exponential backoff
BASE_DELAY_SECONDS=2
MAX_DELAY_SECONDS=3600
JITTER_FACTOR=0.20

## Watchdog: reset jobs stuck in 'processing' for longer than this (seconds).
## Must be well above REQUEST_TIMEOUT_SECONDS to avoid resetting in-flight jobs.
PROCESSING_JOB_TIMEOUT_SECONDS=300

## Idempotency key TTL (hours). After this window the same key can be reused.
IDEMPOTENCY_TTL_HOURS=24

## Circuit breaker: open after CIRCUIT_BREAKER_THRESHOLD failures within
## CIRCUIT_BREAKER_WINDOW_SECONDS. Stays open for CIRCUIT_BREAKER_RECOVERY_SECONDS,
## then allows one half-open probe. On success the circuit resets to closed.
CIRCUIT_BREAKER_THRESHOLD=10
CIRCUIT_BREAKER_WINDOW_SECONDS=60
CIRCUIT_BREAKER_RECOVERY_SECONDS=300

## Mock receiver
## FORCE_FAIL_COUNT=5: deterministic demo (5 failures then success per event)
## FORCE_FAIL_COUNT=0: random 70% failure chaos mode
FORCE_FAIL_COUNT=5
