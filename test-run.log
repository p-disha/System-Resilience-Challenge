    dispatcher-1 | {"asctime":"2026-04-08T10:40:13Z","name":"worker",  "message":"[worker-0] started."}
    dispatcher-1 | {"asctime":"2026-04-08T10:40:13Z","name":"main",    "message":"=== Ready — 3 worker(s) running ==="}

  STEP 7: Dispatcher resumes from attempt 4
    dispatcher-1 | {"asctime":"2026-04-08T10:40:13Z","message":"[18ba35fd] Attempt 4 FAILED in 0.02s — retry in 15.6s at 10:40:28 UTC. Error: HTTP 500: {\"forced_fail\":\"4/5\"}"}
    dispatcher-1 | {"asctime":"2026-04-08T10:40:28Z","message":"[18ba35fd] Attempt 5 FAILED in 0.01s — retry in 29.9s at 10:40:58 UTC. Error: HTTP 500: {\"forced_fail\":\"5/5\"}"}
